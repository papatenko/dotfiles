[user]
	name = papatenko
	email = justinkondratenko@proton.me
[core]
	editor = nvim
	pager = delta
[init]
	defaultBranch = main
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
	side-by-side = true
	syntax-theme = base16
[merge]
	conflictstyle = zdiff3
[diff]
	algorithm = histogram
	colorMoved = default
[push]
	autoSetupRemote = true
	followTags = true
[pull]
	rebase = true
[rerere]
	enabled = true
[fetch]
	prune = true
[alias]
	lg = log --oneline --graph --decorate --all
	undo = reset --soft HEAD~1
	amend = commit --amend --no-edit
