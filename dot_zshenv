# Better Man Pages
export MANPAGER='nvim +Man!'

# FZF — fd backend respects .gitignore
export FZF_DEFAULT_COMMAND='fd --type f --hidden --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --hidden --exclude .git'
export FZF_DEFAULT_OPTS='--height 60% --layout=reverse --border --preview-window=right:60%'

export EDITOR="nvim"

export PATH="$HOME/.local/bin:$HOME/bin:$HOME/.opencode/bin:/usr/local/cuda-12.3/bin:$HOME/.fzf/bin:$PATH"

# Ollama cuda support
export LD_LIBRARY_PATH="/usr/local/cuda-12.3/lib64:$LD_LIBRARY_PATH"
