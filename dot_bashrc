# .bashrc
# Source global definitions
if [ -f /etc/bashrc ]; then
    . /etc/bashrc
fi

# User specific environment
if ! [[ "$PATH" =~ "$HOME/.local/bin:$HOME/bin:" ]]; then
    PATH="$HOME/.local/bin:$HOME/bin:/usr/local/cuda-12.3/bin:$PATH"
fi
export PATH

# Uncomment the following line if you don't like systemctl's auto-paging feature:
# export SYSTEMD_PAGER=

# User specific aliases and functions
if [ -d ~/.bashrc.d ]; then
    for rc in ~/.bashrc.d/*; do
        if [ -f "$rc" ]; then
            . "$rc"
        fi
    done
fi
unset rc

eval "$(zoxide init --cmd cd bash)"
eval "$(fzf --bash)"
export LD_LIBRARY_PATH=/usr/local/cuda-12.3/lib64:$LD_LIBRARY_PATH

# !! Contents within this block are managed by 'conda init' !!
__conda_setup="$('/home/jkondratenko/anaconda3/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "/home/jkondratenko/anaconda3/etc/profile.d/conda.sh" ]; then
        . "/home/jkondratenko/anaconda3/etc/profile.d/conda.sh"
    else
        export PATH="/home/jkondratenko/anaconda3/bin:$PATH"
    fi
fi
unset __conda_setup
